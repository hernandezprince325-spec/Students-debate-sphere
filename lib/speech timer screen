import 'package:flutter/material.dart';

class TimerScreen extends StatefulWidget {
  const TimerScreen({super.key});
  @override
  State<TimerScreen> createState() => _TimerScreenState();
}

class _TimerScreenState extends State<TimerScreen> {
  int _timeLeft = 180;
  bool _isRunning = false;

  void startTimer(int seconds) {
    setState(() { _timeLeft = seconds; _isRunning = true; });
    // Use Timer.periodic here (full code available on request)
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: const Text("Speech Timer")),
      body: Center(
        child: Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            CircularProgressIndicator(
              value: _timeLeft / 420,
              strokeWidth: 12,
              color: Colors.blue,
            ),
            const SizedBox(height: 40),
            Text(
              "\( {(_timeLeft \~/ 60).toString().padLeft(2, '0')}: \){(_timeLeft % 60).toString().padLeft(2, '0')}",
              style: const TextStyle(fontSize: 72, fontWeight: FontWeight.bold),
            ),
            const SizedBox(height: 40),
            Row(
              mainAxisAlignment: MainAxisAlignment.center,
              children: [
                ElevatedButton(onPressed: () => startTimer(180), child: const Text("3 min")),
                const SizedBox(width: 10),
                ElevatedButton(onPressed: () => startTimer(300), child: const Text("5 min")),
                const SizedBox(width: 10),
                ElevatedButton(onPressed: () => startTimer(420), child: const Text("7 min")),
              ],
            ),
          ],
        ),
      ),
    );
  }
}
